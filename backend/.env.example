# ============================================
# 유니로드 Backend 환경 변수 (복사 후 .env로 저장하고 값 채우기)
# ============================================

# --- 필수 ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
GEMINI_API_KEY=your-gemini-api-key

# --- JWT 인증 (Supabase 대시보드에서 확인) ---
SUPABASE_JWT_SECRET=your-jwt-secret

# --- 선택: Supabase 관리자 작업용 ---
# SUPABASE_SERVICE_ROLE_KEY=

# --- 서버 ---
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# --- 선택: Google Analytics 4 ---
# GA4_PROPERTY_ID=521910579
# GOOGLE_APPLICATION_CREDENTIALS=

# --- 선택: 결제 (Polar / Gumroad) ---
# POLAR_WEBHOOK_SECRET=
# POLAR_ACCESS_TOKEN=
# GUMROAD_WEBHOOK_TOKEN=

# --- 선택: 점수 변환 가이드 PDF URL ---
# SCORE_CONVERSION_GUIDE_URL=

# --- 선택: 생기부 PDF 파서 튜닝 ---
# SCHOOL_RECORD_MAX_PDF_MB=30
# SCHOOL_RECORD_PDF_WORD_X_TOLERANCE=2
# SCHOOL_RECORD_PDF_WORD_Y_TOLERANCE=2
# SCHOOL_RECORD_PDF_LINE_CLUSTER_TOLERANCE=1.8

# --- 선택: 생기부 Gemini 파서 튜닝 ---
# SCHOOL_RECORD_GEMINI_PARSE_MODEL=gemini-2.5-flash-preview
# SCHOOL_RECORD_GEMINI_MAX_INPUT_CHARS=120000
