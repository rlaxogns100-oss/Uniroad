{
  "name": "uniroad-frontend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:ios": "VITE_API_BASE_URL=https://uni2road.com VITE_PRE_DEPLOY=false tsc && VITE_API_BASE_URL=https://uni2road.com VITE_PRE_DEPLOY=false vite build --mode capacitor",
    "build:ios:local": "tsc && vite build --mode capacitor",
    "cap:ios": "npm run build:ios && npx cap sync ios",
    "cap:ios:local": "npm run build:ios:local && npx cap sync ios",
    "cap:open:ios": "npx cap open ios",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/ios": "^8.0.2",
    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "^2.93.3",
    "@types/uuid": "^10.0.0",
    "axios": "^1.6.5",
    "canvas-confetti": "^1.9.4",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-ga4": "^2.1.0",
    "react-router-dom": "^6.21.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.7.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  }
}
