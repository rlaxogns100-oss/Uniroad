{
  "dashboard": {
    "name": "Uniroad Golden Path",
    "description": "유입, 활성화, 결제, 리텐션 핵심 대시보드"
  },
  "cohorts": [
    {
      "name": "Paid Users",
      "description": "결제 완료 이벤트가 1회 이상 있는 사용자",
      "event": "payment_completed"
    }
  ],
  "insights": [
    {
      "name": "Daily Visitors",
      "type": "trends",
      "event": "page_view",
      "breakdown": null,
      "date_from": "-30d"
    },
    {
      "name": "Traffic Source Mix",
      "type": "trends",
      "event": "page_view",
      "breakdown": "utm_source",
      "display": "ActionsPie",
      "date_from": "-30d"
    },
    {
      "name": "Device Mix",
      "type": "trends",
      "event": "page_view",
      "breakdown": "device_type",
      "display": "ActionsPie",
      "date_from": "-30d"
    },
    {
      "name": "Activation Funnel",
      "type": "funnel",
      "steps": [
        "page_view",
        "chat_message_sent",
        "login_click",
        "login_completed"
      ],
      "date_from": "-30d"
    },
    {
      "name": "Signup Funnel",
      "type": "funnel",
      "steps": [
        "page_view",
        "auth_modal_view",
        "signup_click",
        "signup_completed"
      ],
      "date_from": "-30d"
    },
    {
      "name": "Revenue Funnel",
      "type": "funnel",
      "steps": [
        "paywall_view",
        "payment_cta_click",
        "payment_method_modal_view",
        "payment_method_selected",
        "payment_started",
        "payment_completed"
      ],
      "breakdown": "paywall_reason",
      "date_from": "-30d"
    },
    {
      "name": "Paywall Reason Mix",
      "type": "trends",
      "event": "paywall_view",
      "breakdown": "paywall_reason",
      "display": "ActionsPie",
      "date_from": "-30d"
    },
    {
      "name": "Payment Method Mix",
      "type": "trends",
      "event": "payment_method_selected",
      "breakdown": "payment_method",
      "display": "ActionsPie",
      "date_from": "-30d"
    },
    {
      "name": "Payment Starts by Method",
      "type": "trends",
      "event": "payment_started",
      "breakdown": "payment_method",
      "display": "ActionsBarValue",
      "date_from": "-30d"
    },
    {
      "name": "Payment Validation Failures",
      "type": "trends",
      "event": "payment_validation_failed",
      "breakdown": "error_message",
      "display": "ActionsBarValue",
      "date_from": "-30d"
    },
    {
      "name": "Payment Modal Dismissals",
      "type": "trends",
      "event": "payment_method_modal_dismissed",
      "breakdown": "modal_type",
      "display": "ActionsBarValue",
      "date_from": "-30d"
    },
    {
      "name": "Bank Transfer Journey",
      "type": "funnel",
      "steps": [
        "payment_method_selected",
        "payment_info_copied",
        "payment_started",
        "payment_completed"
      ],
      "date_from": "-30d",
      "properties": [
        {
          "key": "payment_method",
          "value": [
            "bank_transfer"
          ],
          "operator": "exact",
          "type": "event"
        }
      ]
    },
    {
      "name": "Feature Usage (Paid Users)",
      "type": "trends",
      "events": [
        "feature_card_click",
        "school_record_analysis_requested",
        "score_saved",
        "payment_completed"
      ],
      "cohort": "Paid Users",
      "date_from": "-30d"
    },
    {
      "name": "Paid User Retention",
      "type": "retention",
      "event": "page_view",
      "cohort": "Paid Users",
      "date_from": "-30d"
    }
  ]
}
