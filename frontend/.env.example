# ============================================
# 유니로드 Frontend 환경 변수 (로컬 개발 시 .env로 복사 후 값 채우기)
# ============================================

# API 서버 (로컬 개발 시 백엔드 주소)
VITE_API_BASE_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# Supabase (OAuth·인증용 — 백엔드와 동일 프로젝트)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 로컬/모바일 개발 시 true (배포 빌드 시에는 제거 또는 false)
# VITE_PRE_DEPLOY=true

# 선택: PostHog 분석
# VITE_PUBLIC_POSTHOG_KEY=

# 선택: 토스 결제 위젯 (실서비스 URL)
# VITE_TOSS_WIDGET_APPROVAL_ONETIME_URL=
# VITE_TOSS_WIDGET_APPROVAL_BILLING_URL=

# 선택: PayApp 로컬/운영 테스트
# VITE_PAYAPP_USERID=
